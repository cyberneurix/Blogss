1c:[["$","div","div-0",{"className":"key-takeaways-block","children":["\n",["$","h2","h2-0",{"className":"takeaways-title","data-section":"true","itemProp":"name","node":{"type":"element","tagName":"h2","properties":{"className":["takeaways-title"],"itemProp":["name"]},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":4,"column":45,"offset":80},"end":{"line":4,"column":58,"offset":93}}}],"position":{"start":{"line":4,"column":1,"offset":36},"end":{"line":4,"column":63,"offset":98}}},"children":"Key Takeaways"}],"\n",["$","ul","ul-0",{"className":"takeaways-list","data-section":"true","node":{"type":"element","tagName":"ul","properties":{"className":["takeaways-list"]},"children":[{"type":"text","value":"\n","position":{"start":{"line":5,"column":28,"offset":126},"end":{"line":6,"column":1,"offset":127}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Neuroplasticity — the brain's ability to reorganise itself by forming new neural connections — is the biological mechanism underpinning all learning, memory, and cognitive adaptation.","position":{"start":{"line":6,"column":5,"offset":131},"end":{"line":6,"column":188,"offset":314}}}],"position":{"start":{"line":6,"column":1,"offset":127},"end":{"line":6,"column":193,"offset":319}}},{"type":"text","value":"\n","position":{"start":{"line":6,"column":193,"offset":319},"end":{"line":7,"column":1,"offset":320}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"AI personalisation of cognitive training leverages neuroplasticity principles to adapt difficulty, modality, and pacing to the learner's real-time neural feedback — outperforming fixed curricula.","position":{"start":{"line":7,"column":5,"offset":324},"end":{"line":7,"column":200,"offset":519}}}],"position":{"start":{"line":7,"column":1,"offset":320},"end":{"line":7,"column":205,"offset":524}}},{"type":"text","value":"\n","position":{"start":{"line":7,"column":205,"o