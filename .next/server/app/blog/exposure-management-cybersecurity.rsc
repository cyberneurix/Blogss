52:["$","div","div-2",{"children":["\n  ",["$","div","div-0",{"children":["\n    ",["$","h3","h3-0",{"className":"scroll-highlight-section text-2xl md:text-3xl font-bold text-slate-200 mt-8 mb-5","data-section":"true","itemProp":"name","node":{"type":"element","tagName":"h3","properties":{"itemProp":["name"]},"children":[{"type":"text","value":"What is exposure management in cybersecurity?","position":{"start":{"line":135,"column":25,"offset":8469},"end":{"line":135,"column":70,"offset":8514}}}],"position":{"start":{"line":135,"column":5,"offset":8449},"end":{"line":135,"column":75,"offset":8519}}},"children":"What is exposure management in cybersecurity?"}],"\n    ",["$","div","div-0",{"children":["\n      ",["$","p","p-0",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","itemProp":"text","node":{"type":"element","tagName":"p","properties":{"itemProp":["text"]},"children":[{"type":"text","value":"Exposure management is the practice of continuously finding, prioritising, and reducing the attack surface before adversaries exploit it. It shifts the focus from 'what happened' to 'what could an attacker do right now'.","position":{"start":{"line":137,"column":26,"offset":8555},"end":{"line":137,"column":246,"offset":8775}}}],"position":{"start":{"line":137,"column":7,"offset":8536},"end":{"line":137,"column":250,"offset":8779}}},"children":"Exposure management is the practice of continuously finding, prioritising, and reducing the attack surface before adversaries exploit it. It shifts the focus from 'what happened' to 'what could an attacker do right now'."}],"\n    "]}],"\n  "]}],"\n  ",["$","div","div-1",{"children":["\n    ",["$","h3","h3-0",{"className":"scroll-highlight-section text-2xl md:text-3xl font-bold text-slate-200 mt-8 mb-5","data-section":"true","itemProp":"name","node":{"type":"element","tagName":"h3","properties":{"itemProp":["name"]},"children":[{"type":"text","value":"How is CTEM different from traditional vulnerability management?","position":{"start":{"line":141,"column":25,"offset":8832},"end":{"line":141,"column":89,"offset":8896}}}],"position":{"start":{"line":141,"column":5,"offset":8812},"end":{"line":141,"column":94,"offset":8901}}},"children":"How is CTEM different from traditional vulnerability management?"}],"\n    ",["$","div","div-0",{"children":["\n      ",["$","p","p-0",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","itemProp":"text","node":{"type":"element","tagName":"p","properties":{"itemProp":["text"]},"children":[{"type":"text","value":"Traditional vulnerability management focuses on patching CVEs. CTEM (Continuous Threat Exposure Management) is a broader framework that includes validating attack paths, assessing identity risks, and prioritising by business impact rather than just technical severity.","position":{"start":{"line":143,"column":26,"offset":8937},"end":{"line":143,"column":294,"offset":9205}}}],"position":{"start":{"line":143,"column":7,"offset":8918},"end":{"line":143,"column":298,"offset":9209}}},"children":"Traditional vulnerability management focuses on patching CVEs. CTEM (Continuous Threat Exposure Management) is a broader framework that includes validating attack paths, assessing identity risks, and prioritising by business impact rather than just technical severity."}],"\n    "]}],"\n  "]}],"\n  ",["$","div","div-2",{"children":["\n    ",["$","h3","h3-0",{"className":"scroll-highlight-section text-2xl md:text-3xl font-bold text-slate-200 mt-8 mb-5","data-section":"true","itemProp":"name","node":{"type":"element","tagName":"h3","properties":{"itemProp":["name"]},"children":[{"type":"text","value":"Why is prioritisation critical in exposure management?","position":{"start":{"line":147,"column":25,"offset":9262},"end":{"line":147,"column":79,"offset":9316}}}],"position":{"start":{"line":147,"column":5,"offset":9242},"end":{"line":147,"column":84,"offset":9321}}},"children":"Why is prioritisation critical in exposure management?"}],"\n    ",["$","div","div-0",{"children":["\n      ",["$","p","p-0",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","itemProp":"text","node":{"type":"element","tagName":"p","properties":{"itemProp":["text"]},"children":[{"type":"text","value":"Every organisation has thousands of vulnerabilities, but only a fraction are reachable by attackers. Prioritisation based on exploitability and business context ensures teams fix the exposures that actually reduce risk.","position":{"start":{"line":149,"column":26,"offset":9357},"end":{"line":149,"column":245,"offset":9576}}}],"position":{"start":{"line":149,"column":7,"offset":9338},"end":{"line":149,"column":249,"offset":9580}}},"children":"Every organisation has thousands of vulnerabilities, but only a fraction are reachable by attackers. Prioritisation based on exploitability and business context ensures teams fix the exposures that actually reduce risk."}],"\n    "]}],"\n  "]}],"\n"]}]
