2c:["$","p","p-3",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","node":{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"● ","position":{"start":{"line":24,"column":1,"offset":1766},"end":{"line":24,"column":3,"offset":1768}}},{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"You can only detect what you know to look for","position":{"start":{"line":24,"column":5,"offset":1770},"end":{"line":24,"column":50,"offset":1815}}}],"position":{"start":{"line":24,"column":3,"offset":1768},"end":{"line":24,"column":52,"offset":1817}}},{"type":"text","value":" — Novel techniques, living-off-the-land attacks, and zero-days bypass detection logic by definition. Attackers study your detection stack before they attack.","position":{"start":{"line":24,"column":52,"offset":1817},"end":{"line":24,"column":210,"offset":1975}}}],"position":{"start":{"line":24,"column":1,"offset":1766},"end":{"line":24,"column":210,"offset":1975}}},"children":["● ",["$","strong","strong-0",{"children":"You can only detect what you know to look for"}]," — Novel techniques, living-off-the-land attacks, and zero-days bypass detection logic by definition. Attackers study your detection stack before they attack."]}]
2d:["$","p","p-4",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","node":{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"● ","position":{"start":{"line":26,"column":1,"offset":1977},"end":{"line":26,"column":3,"offset":1979}}},{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"The alert volume problem is unsolvable at the detection layer","position":{"start":{"line":26,"column":5,"offset":1981},"end":{"line":26,"column":66,"offset":2042}}}],"position":{"start":{"line":26,"column":3,"offset":1979},"end":{"line":26,"column":68,"offset":2044}}},{"type":"text","value":" — More telemetry produces more alerts. More alerts produce more fatigue. More fatigue produces more misses. The feedback loop cannot be broken by adding more detection.","position":{"start":{"line":26,"column":68,"offset":2044},"end":{"line":26,"column":237,"offset":2213}}}],"position":{"start":{"line":26,"column":1,"offset":1977},"end":{"line":26,"column":237,"offset":2213}}},"children":["● ",["$","strong","strong-0",{"children":"The alert volume problem is unsolvable at the detection layer"}]," — More telemetry produces more alerts. More alerts produce more fatigue. More fatigue produces more misses. The feedback loop cannot be broken by adding more detection."]}]
