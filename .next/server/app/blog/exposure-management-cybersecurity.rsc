27:["$","p","p-0",{"className":"scroll-highlight-section mb-6 leading-[1.9] text-lg text-zinc-300 font-light tracking-wide","data-section":"true","node":{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"Every breach follows the same pattern. Attackers move in. Dwell for weeks. Execute. Then your detection stack fires — after the damage is done. The detection-first model was built to catch threats after they enter. Exposure management asks a different question entirely: why let them find a way in at all?","position":{"start":{"line":15,"column":1,"offset":960},"end":{"line":15,"column":306,"offset":1265}}}],"position":{"start":{"line":15,"column":1,"offset":960},"end":{"line":15,"column":306,"offset":1265}}},"children":"Every breach follows the same pattern. Attackers move in. Dwell for weeks. Execute. Then your detection stack fires — after the damage is done. The detection-first model was built to catch threats after they enter. Exposure management asks a different question entirely: why let them find a way in at all?"}]
