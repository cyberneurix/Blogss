1c:["$","$L20",null,{"className":"prose-custom blog-content scroll-highlight-container","children":[[["$","div","div-0",{"className":"key-takeaways-block","children":["\n",["$","h2","h2-0",{"className":"takeaways-title","data-section":"true","itemProp":"name","node":{"type":"element","tagName":"h2","properties":{"className":["takeaways-title"],"itemProp":["name"]},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":4,"column":45,"offset":80},"end":{"line":4,"column":58,"offset":93}}}],"position":{"start":{"line":4,"column":1,"offset":36},"end":{"line":4,"column":63,"offset":98}}},"children":"Key Takeaways"}],"\n",["$","ul","ul-0",{"className":"takeaways-list","data-section":"true","node":{"type":"element","tagName":"ul","properties":{"className":["takeaways-list"]},"children":[{"type":"text","value":"\n","position":{"start":{"line":5,"column":28,"offset":126},"end":{"line":6,"column":1,"offset":127}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Misconfiguration is the leading cause of cloud security incidents — not zero-days or sophisticated exploits, but default settings and access control gaps.","position":{"start":{"line":6,"column":5,"offset":131},"end":{"line":6,"column":159,"offset":285}}}],"position":{"start":{"line":6,"column":1,"offset":127},"end":{"line":6,"column":164,"offset":290}}},{"type":"text","value":"\n","position":{"start":{"line":6,"column":164,"offset":290},"end":{"line":7,"column":1,"offset":291}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"The shared responsibility model means cloud providers secure the infrastructure, but organisations are responsible for everything they build and configure on top of it.","position":{"start":{"line":7,"column":5,"offset":295},"end":{"line":7,"column":173,"offset":463}}}],"position":{"start":{"line":7,"column":1,"offset":291},"end":{"line":7,"column":178,"offset":468}}},{"type":"text","value":"\n","position":{"start":{"line":7,"column":178,"offset":468},"end":{"line":8,"column":1,"offset":469}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"CSPM tools continuously assess cloud configurations against security benchmarks — identifying misconfigurations before attackers do.","position":{"start":{"line":8,"column":5,"offset":473},"end":{"line":8,"column":137,"offset":605}}}],"position":{"start":{"line":8,"column":1,"offset":469},"end":{"line":8,"column":142,"offset":610}}},{"type":"text","value":"\n","position":{"start":{"line":8,"column":142,"offset":610},"end":{"line":9,"column":1,"offset":611}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Identity misconfigurations in cloud environments (over-permissioned IAM roles, long-lived tokens) create lateral movement pathways that traditional perimeter tools cannot see.","position":{"start":{"line":9,"column":5,"offset":615},"end":{"line":9,"column":180,"offset":790}}}],"position":{"start":{"line":9,"column":1,"offset":611},"end":{"line":9,"column":185,"offset":795}}},{"type":"text","value":"\n","position":{"start":{"line":9,"column":185,"offset":795},"end":{"line":10,"column":1,"offset":796}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Multi-cloud environments amplify the misconfiguration risk — each cloud provider has distinct configuration models, creating gaps at the boundaries.","position":{"start":{"line":10,"column":5,"offset":800},"end":{"line":10,"column":153,"offset":948}}}],"position":{"start":{"line":10,"column":1,"offset":796},"end":{"line":10,"column":158,"offset":953}}},{"type":"text","value":"\n","position":{"start":{"line":10,"column":158,"offset":953},"end":{"line":11,"column":1,"offset":954}}}],"position":{"start":{"line":5,"column":1,"offset":99},"end":{"line":11,"column":6,"offset":959}}},"children":["\n",["$","li","li-0",{"children":"Misconfiguration is the leading cause of cloud security incidents — not zero-days or sophisticated exploits, but default settings and access control gaps."}],"\n",["$","li","li-1",{"children":"The shared responsibility model means cloud providers secure the infrastructure, but organisations are responsible for everything they build and configure on top of it."}],"\n",["$","li","li-2",{"children":"CSPM tools continuously assess cloud configurations against security benchmarks — identifying misconfigurations before attackers do."}],"\n",["$","li","li-3",{"children":"Identity misconfigurations in cloud environments (over-permissioned IAM roles, long-lived tokens) create lateral movement pathways that traditional perimeter tools cannot see."}],"\n","$L21","\n"]}],"\n"]}],"\n## How Many Cloud Misconfigurations Exist in Your Environment Right Now?\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35"],"$L36"]}]
