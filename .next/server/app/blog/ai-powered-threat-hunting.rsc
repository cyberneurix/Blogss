,"offset":487}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Behavioural baselining at scale is only possible with machine learning — no human team can maintain per-user, per-device, per-service normality models across enterprise environments.","position":{"start":{"line":8,"column":5,"offset":491},"end":{"line":8,"column":187,"offset":673}}}],"position":{"start":{"line":8,"column":1,"offset":487},"end":{"line":8,"column":192,"offset":678}}},{"type":"text","value":"\n","position":{"start":{"line":8,"column":192,"offset":678},"end":{"line":9,"column":1,"offset":679}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Human-AI collaboration is the operational model: AI generates hypotheses and surfaces anomalies; human hunters validate, investigate, and feed back corrections.","position":{"start":{"line":9,"column":5,"offset":683},"end":{"line":9,"column":165,"offset":843}}}],"position":{"start":{"line":9,"column":1,"offset":679},"end":{"line":9,"column":170,"offset":848}}},{"type":"text","value":"\n","position":{"start":{"line":9,"column":170,"offset":848},"end":{"line":10,"column":1,"offset":849}}},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Temporal correlation spanning days or weeks — an attacker's slow-burn lateral movement — is where AI hunting consistently outperforms rule-based detection.","position":{"start":{"line":10,"column":5,"offset":853},"end":{"line":10,"column":160,"offset":1008}}}],"position":{"start":{"line":10,"column":1,"offset":849},"end":{"line":10,"column":165,"offset":1013}}},{"type":"text","value":"\n","position":{"start":{"line":10,"column":165,"offset":1013},"end":{"line":11,"column":1,"offset":1014}}}],"position":{"start":{"line":5,"column":1,"offset":99},"end":{"line":11,"column":6,"offset":1019}}},"children":["\n",["$","li","li-0",{"children":"AI-powered threat hunting detects anomalies and behavioural deviations rather th